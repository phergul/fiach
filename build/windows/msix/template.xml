<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="fiach"
        Arguments=""
        InstallLocation="C:\Program Files\phergul\Fiach">
    </Installer>
    <PackageInformation
        PackageName="Fiach"
        PackageDisplayName="Fiach"
        PublisherName="CN=phergul"
        PublisherDisplayName="phergul"
        Version="0.1.0.0"
        PackageDescription="A general-purpose mod manager for any game">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.phergul.fiach"
                Description="A general-purpose mod manager for any game"
                DisplayName="Fiach"
                ExecutableName="fiach"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Fiach</DisplayName>
            <PublisherDisplayName>phergul</PublisherDisplayName>
            <Description>A general-purpose mod manager for any game</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="fiach.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
